# Environment Variables for Vitra
# Copy this file to .env.local and fill in values

# Database — PostgreSQL connection string
DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/vitra"

# NextAuth
AUTH_SECRET="your-secret-here-generate-with-openssl-rand-base64-32"
NEXTAUTH_URL="http://localhost:3000"

# Google OAuth (optional)
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# OpenAI API key (leave blank to use mock AI responses)
OPENAI_API_KEY=""

# USDA FoodData Central — enables searching USDA's ~600k food database from the
# Log Food page. Get a free key at https://fdc.nal.usda.gov/api-key-signup.html
# Leave blank to disable USDA results (Open Food Facts barcode lookup still works).
USDA_API_KEY=""
